# Anthropic API Key (optional - for Stagehand AI browser automation)
# Get your key from: https://console.anthropic.com/
# Note: Not required for Puppeteer-based automation
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Kubernetes Dashboard Credentials (for Test Case 1: kind cluster)
# Generated automatically when running kind cluster tests
# Format: http://localhost:8001/api/v1/namespaces/kubernetes-dashboard/services/https:kubernetes-dashboard:/proxy/
DASHBOARD_URL=http://localhost:8001/api/v1/namespaces/kubernetes-dashboard/services/https:kubernetes-dashboard:/proxy/
DASHBOARD_TOKEN=your-dashboard-token-here

# Note for Test Case 2 (Real Cluster):
# Use test-cases/case-2-real-cluster/cluster-config.json instead of environment variables
# See cluster-config.json for the required format
